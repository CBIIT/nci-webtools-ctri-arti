{
  "name": "server",
  "version": "1.0.0",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node --env-file .env server.js",
    "start:dev": "node --env-file .env --watch-path=. server.js",
    "test:setup": "npx playwright install chromium",
    "test": "npm run test:all",
    "test:all": "npm run test:unit && npm run test:browser",
    "test:unit": "node --env-file test.env --test --experimental-test-coverage --test-reporter=spec",
    "test:browser": "node --env-file test.env integration.js",
    "test:integration": "npm run test:browser",
    "cert": "openssl req -x509 -newkey rsa:2048 -nodes -subj '/C=US/ST=State/L=City/O=Organization/CN=localhost' -keyout key.tmp -out cert.tmp && cat key.tmp cert.tmp > key.pem && rm key.tmp cert.tmp"
  },
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1028.0",
    "@aws-sdk/client-textract": "^3.1029.0",
    "@aws-sdk/client-translate": "^3.1028.0",
    "cms": "*",
    "database": "*",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "gateway": "*",
    "handlebars": "^4.7.9",
    "mammoth": "^1.12.0",
    "node-cron": "^4.2.1",
    "node-forge": "^1.4.0",
    "nodemailer": "^8.0.5",
    "oidc-provider": "^9.8.0",
    "openid-client": "^6.8.2",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.6.205",
    "shared": "*"
  },
  "devDependencies": {
    "playwright": "^1.59.1",
    "supertest": "^7.2.2"
  }
}
